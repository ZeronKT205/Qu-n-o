PORT=5000

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/levents_db?schema=public"

# ============================================
# AUTH (JWT)
# ============================================
JWT_SECRET="your-super-secret-jwt-key"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ============================================
# SEPAY PAYMENT GATEWAY
# Docs: https://developer.sepay.vn/payment-gateway/api-overview/
# ============================================
SEPAY_MERCHANT_ID="your-merchant-id"
SEPAY_SECRET_KEY="your-secret-key"
SEPAY_API_URL="https://pgapi-sandbox.sepay.vn"
SEPAY_WEBHOOK_SECRET="your-webhook-verify-secret"

# Bank account info (for QR generation)
SEPAY_BANK_CODE="MB"
SEPAY_ACCOUNT_NUMBER="0123456789"
SEPAY_ACCOUNT_NAME="LEVENTS FASHION"

# ============================================
# FILE STORAGE (choose one)
# ============================================
# STORAGE_TYPE="local"
# CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
# AWS_S3_BUCKET="levents-assets"

# ============================================
# APP CONFIG
# ============================================
FRONTEND_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000"
